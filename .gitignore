.DS_Store

# Vendored reference implementations — build scaffolding, not ship artifacts
reference/

# Vouch session ledger (local, not shipped)
.vouch/

# context-os per-session read ledger (local telemetry, not shipped)
.context-os/reads-*.jsonl
