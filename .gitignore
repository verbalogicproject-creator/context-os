# Build / runtime noise
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
*.egg-info/
build/
dist/

# Secrets / env — never commit
.env
.env.*
*.key
*.pem

# Data artifacts this plugin must never ship
*.db

